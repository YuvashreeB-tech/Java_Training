class Solution {
    public boolean canAliceWin(int[] nums) {
        int sing=0,doub=0;
        for(int i=0;i<nums.length;i++)
        {
            if(nums[i]<=9)
            sing+=nums[i];
            else
            doub+=nums[i];
            
        }
        if(sing>doub || doub>sing)
        return true;
        else
        return false;
    }
}
